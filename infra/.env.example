# Redis-Stack (ALLES-REDIS — single data store for KV + vector + streams)
REDIS_URL=redis://redis-stack:6379

# Clerk JWT validation (saits-security/terraform/clerk provides JWT template)
CLERK_JWKS_URL=https://<clerk-domain>/.well-known/jwks.json
JWT_AUDIENCE=saits.cloud/production       # or saits.cloud/staging

# Embedding service (any OpenAI-compatible endpoint)
EMBED_URL=https://api.openai.com/v1/embeddings
EMBED_MODEL=text-embedding-3-small
EMBED_API_KEY=sk-...

# Completion service (OpenAI-compatible)
COMPLETION_URL=https://api.openai.com/v1/chat/completions
COMPLETION_MODEL=gpt-4o-mini
# COMPLETION_API_KEY defaults to EMBED_API_KEY if not set

# Vector index tuning
VECTOR_DIM=1536
HNSW_M=16
HNSW_EF_CONSTRUCTION=200

# DPoP
DPOP_REPLAY_TTL=120    # seconds; backed by in-memory dict in dev, Redis SETNX in prod
DPOP_KEYSET_PATH=/run/secrets/dpop_jwks.json

# mTLS (required when profile=gateway)
MTLS_CA_CERT=          # PEM string or path

# pub-sse-bridge (optional — trading-bot event fanout to saitsCloud)
# Set these to enable the bridge in lgateway.
BOT_SSE_URL=                # e.g. https://bot.example.com/logs/sse
BOT_SSE_TOKEN=              # HMAC token for bot's token= auth query param
BOT_TENANT_ID=              # Clerk org / lbus tenant to route events to
BRIDGE_DEDUP_TTL=300        # seconds — Redis SETEX TTL for message-id dedup
BRIDGE_RECONNECT_DELAY=5    # seconds — reconnect delay on disconnect
SSE_READ_BLOCK_MS=5000      # blocking XREAD timeout (ms)
SSE_MAX_BACKLOG=100         # max events per XREAD batch
